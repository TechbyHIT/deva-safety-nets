# =============================================================================
# Deva Safety Nets — production environment (copy to .env on the VPS)
# =============================================================================
# On Hostinger VPS:
#   cd /opt/deva
#   cp .env.example .env
#   nano .env
# =============================================================================

# --- Site (baked into the Docker image at BUILD time) ---
NEXT_PUBLIC_SITE_URL=https://devasafetynets.in
NEXT_PUBLIC_SITE_NAME=Deva Safety Nets
NEXT_PUBLIC_BRAND_PHONE=+917558844405
NEXT_PUBLIC_WHATSAPP=917558844405
NEXT_PUBLIC_EMAIL=devasafetynetskochi@gmail.com
NEXT_PUBLIC_GOOGLE_MAPS_KEY=

# --- Runtime (read when container STARTS) ---
# Host port mapped to container :3000. Use 3000 for testing, 80 after Nginx is set up.
APP_PORT=3000
SITEMAP_PAGE_SIZE=45000
REVALIDATE_SECRET=change-me-to-a-long-random-string
