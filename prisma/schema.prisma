// Prisma schema for the Invisible Grills & Safety Nets platform.
//
// Scaling model
// -------------
// High-quality URLs are generated from COMBINATIONS of a small number of
// curated base entities, not from hand-authored pages:
//
//   /services/[service]                         -> Service
//   /services/[service]/[city]                  -> Service x City
//   /services/[service]/[city]/[area]           -> Service x City x Area
//   /locations/[city] , /locations/[city]/[area]
//   /materials/[material] , /industries/[industry]
//   /compare/[a]-vs-[b] , /blog/[slug] , guides, projects ...
//
// Every combination page is rendered from structured data + a deterministic
// content engine, so each page is unique and useful. Editors can override the
// generated content for any specific combination via ContentOverride, keeping
// full control where it matters without authoring millions of rows.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Taxonomy
// ---------------------------------------------------------------------------

model Category {
  id          String    @id @default(cuid())
  slug        String    @unique
  name        String
  description String
  icon        String? // lucide icon name
  order       Int       @default(0)
  services    Service[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([order])
}

model Service {
  id              String  @id @default(cuid())
  slug            String  @unique
  name            String
  shortName       String?
  category        Category @relation(fields: [categoryId], references: [id])
  categoryId      String
  tagline         String
  summary         String  @db.Text
  // Structured, reusable building blocks used by the content engine.
  benefits        String[]
  features        String[]
  specifications  Json     @default("{}")
  useCases        String[]
  keywords        String[]
  heroImage       String?
  priceMin        Int? // in INR, per sq ft or per unit
  priceMax        Int?
  priceUnit       String? // "sq ft", "running ft", "unit"
  order           Int      @default(0)
  featured        Boolean  @default(false)

  materials       ServiceMaterial[]
  faqs            Faq[]
  projects        Project[]
  reviews         Review[]
  guides          Guide[]
  comparisonsA    Comparison[] @relation("ComparisonA")
  comparisonsB    Comparison[] @relation("ComparisonB")

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([categoryId])
  @@index([featured])
  @@index([order])
}

model Material {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  grade       String? // e.g. SS304, SS316
  summary     String   @db.Text
  properties  Json     @default("{}")
  advantages  String[]
  bestFor     String[]
  order       Int      @default(0)
  services    ServiceMaterial[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Join table so a service can offer several materials with per-pair notes.
model ServiceMaterial {
  service    Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  serviceId  String
  material   Material @relation(fields: [materialId], references: [id], onDelete: Cascade)
  materialId String
  note       String?

  @@id([serviceId, materialId])
  @@index([materialId])
}

model Industry {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  summary     String   @db.Text
  challenges  String[]
  solutions   String[]
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ---------------------------------------------------------------------------
// Geography
// ---------------------------------------------------------------------------

model City {
  id         String   @id @default(cuid())
  slug       String   @unique
  name       String
  state      String
  region     String? // South, North, ...
  latitude   Float?
  longitude  Float?
  population Int?
  landmarks  String[]
  intro      String?  @db.Text
  featured   Boolean  @default(false)
  order      Int      @default(0)
  areas      Area[]
  projects   Project[]
  reviews    Review[]
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([state])
  @@index([featured])
}

model Area {
  id        String   @id @default(cuid())
  slug      String
  name      String
  city      City     @relation(fields: [cityId], references: [id], onDelete: Cascade)
  cityId    String
  pincode   String?
  // Location hierarchy: tier 2 = municipality/town, 3 = major locality,
  // 4 = IT corridor, 5 = island, 6 = residential, 7 = airport region, etc.
  tier      Int      @default(3)
  tierLabel String?
  landmarks String[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([cityId, slug])
  @@index([cityId])
  @@index([tier])
}

// Reusable content dimension multiplied against services and locations to
// generate high-value long-tail pages (Service x PropertyType,
// Service x City x PropertyType) without inventing new place names.
model PropertyType {
  id        String   @id @default(cuid())
  slug      String   @unique
  name      String
  plural    String
  summary   String   @db.Text
  concerns  String[] // safety concerns specific to this property type
  examples  String[]
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([order])
}

// ---------------------------------------------------------------------------
// Content
// ---------------------------------------------------------------------------

model Faq {
  id         String   @id @default(cuid())
  question   String
  answer     String   @db.Text
  service    Service? @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  serviceId  String?
  scope      FaqScope @default(GENERAL)
  order      Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([serviceId])
  @@index([scope])
}

enum FaqScope {
  GENERAL
  SERVICE
  PRICING
  INSTALLATION
  MAINTENANCE
  SAFETY
}

model Guide {
  id          String    @id @default(cuid())
  slug        String    @unique
  title       String
  type        GuideType
  service     Service?  @relation(fields: [serviceId], references: [id])
  serviceId   String?
  excerpt     String    @db.Text
  body        String    @db.Text
  steps       Json      @default("[]")
  readMinutes Int       @default(6)
  heroImage   String?
  published   Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([type])
  @@index([serviceId])
}

enum GuideType {
  INSTALLATION
  MAINTENANCE
  BUYING
  SAFETY
}

model BlogPost {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  excerpt     String   @db.Text
  body        String   @db.Text
  tags        String[]
  heroImage   String?
  author      String   @default("Editorial Team")
  readMinutes Int      @default(5)
  published   Boolean  @default(true)
  publishedAt DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([published, publishedAt])
}

model Project {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  service     Service? @relation(fields: [serviceId], references: [id])
  serviceId   String?
  city        City?    @relation(fields: [cityId], references: [id])
  cityId      String?
  summary     String   @db.Text
  challenge   String?  @db.Text
  solution    String?  @db.Text
  outcome     String?  @db.Text
  images      String[]
  beforeImage String?
  afterImage  String?
  completedAt DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([serviceId])
  @@index([cityId])
}

model Review {
  id         String   @id @default(cuid())
  author     String
  rating     Int      @default(5)
  body       String   @db.Text
  service    Service? @relation(fields: [serviceId], references: [id])
  serviceId  String?
  city       City?    @relation(fields: [cityId], references: [id])
  cityId     String?
  verified   Boolean  @default(true)
  createdAt  DateTime @default(now())

  @@index([serviceId])
  @@index([cityId])
  @@index([rating])
}

model Comparison {
  id        String   @id @default(cuid())
  slug      String   @unique // e.g. "invisible-grills-vs-safety-nets"
  serviceA  Service  @relation("ComparisonA", fields: [serviceAId], references: [id])
  serviceAId String
  serviceB  Service  @relation("ComparisonB", fields: [serviceBId], references: [id])
  serviceBId String
  intro     String   @db.Text
  criteria  Json     @default("[]") // [{label, a, b}]
  verdict   String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([serviceAId, serviceBId])
}

// Editorial overrides for any generated combination page. Keeps millions of
// generated pages consistent while letting editors tune the most valuable ones.
model ContentOverride {
  id        String   @id @default(cuid())
  routeKey  String   @unique // e.g. "services/balcony-invisible-grills/bengaluru/whitefield"
  title     String?
  metaTitle String?
  metaDesc  String?  @db.Text
  intro     String?  @db.Text
  bodyBlocks Json    @default("[]")
  noindex   Boolean  @default(false)
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
}

// ---------------------------------------------------------------------------
// Lead generation
// ---------------------------------------------------------------------------

model Lead {
  id        String     @id @default(cuid())
  name      String
  phone     String
  email     String?
  message   String?    @db.Text
  service   String?
  city      String?
  source    String? // route the lead came from
  status    LeadStatus @default(NEW)
  createdAt DateTime   @default(now())

  @@index([status])
  @@index([createdAt])
}

enum LeadStatus {
  NEW
  CONTACTED
  QUOTED
  WON
  LOST
}
